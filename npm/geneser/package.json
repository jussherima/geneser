{
  "name": "geneser",
  "version": "1.1.2",
  "description": "CLI tool to generate Flutter project architectures from famous templates",
  "bin": {
    "geneser": "bin/geneser"
  },
  "optionalDependencies": {
    "geneser-linux-x64": "1.1.2",
    "geneser-darwin-x64": "1.1.2",
    "geneser-darwin-arm64": "1.1.2",
    "geneser-windows-x64": "1.1.2"
